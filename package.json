{
  "name": "story-weaver-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  },
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"pnpm run dev:frontend\" \"pnpm run dev:electron\"",
    "dev:web": "concurrently -k \"pnpm run dev:frontend\" \"pnpm run dev:backend\"",
    "dev:frontend": "pnpm --filter @story-weaver/frontend dev",
    "dev:backend": "pnpm --filter @story-weaver/backend dev",
    "dev:electron": "pnpm run build:shared && pnpm run build:backend && pnpm run build:electron && electron-rebuild -f -w better-sqlite3 && wait-on tcp:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "start:server": "pnpm --filter @story-weaver/backend start",
    "start:web": "pnpm run build && pnpm run start:server",
    "build": "pnpm run build:shared && pnpm run build:backend && pnpm run build:frontend && pnpm run build:electron",
    "build:shared": "pnpm --filter @story-weaver/shared build",
    "build:backend": "pnpm --filter @story-weaver/backend build",
    "build:frontend": "pnpm --filter @story-weaver/frontend build",
    "build:electron": "tsc -p tsconfig.node.json",
    "typecheck": "pnpm --filter @story-weaver/shared typecheck && pnpm --filter @story-weaver/backend typecheck && pnpm --filter @story-weaver/frontend typecheck && tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.server.json",
    "test": "pnpm rebuild better-sqlite3 && vitest run",
    "test:watch": "vitest",
    "smoke:browser-persistence": "node scripts/smoke-browser-persistence.mjs",
    "smoke:electron-package": "node scripts/smoke-electron-package.mjs",
    "package": "pnpm run build && electron-builder",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@story-weaver/backend": "workspace:*",
    "@story-weaver/frontend": "workspace:*",
    "@story-weaver/shared": "workspace:*",
    "ai": "^6.0.168",
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.45.2",
    "epub-gen-memory": "^1.0.9",
    "fastify": "^5.8.5",
    "lucide-react": "^1.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^25.0.1",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^2.5.2",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.1",
    "zod": "^4.4.1",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  }
}
