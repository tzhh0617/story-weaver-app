{
  "name": "@story-weaver/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "import": "./dist/contracts.js"
    },
    "./settings": {
      "types": "./dist/settings.d.ts",
      "import": "./dist/settings.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js"
    },
    "./schemas/book-schemas": {
      "types": "./dist/schemas/book-schemas.d.ts",
      "import": "./dist/schemas/book-schemas.js"
    },
    "./schemas/model-schemas": {
      "types": "./dist/schemas/model-schemas.d.ts",
      "import": "./dist/schemas/model-schemas.js"
    },
    "./schemas/settings-schemas": {
      "types": "./dist/schemas/settings-schemas.d.ts",
      "import": "./dist/schemas/settings-schemas.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "zod": "^4.4.1"
  }
}
